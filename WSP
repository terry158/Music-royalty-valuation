import streamlit as st
import pandas as pd
import plotly.express as px

# --- Core Logic ---
def calculate_valuation(initial, decay, discount, years, exit_mult):
    data = []
    current_cf = initial
    total_npv = 0
    for year in range(1, years + 1):
        current_cf *= (1 - decay)
        pv = current_cf / ((1 + discount) ** year)
        total_npv += pv
        data.append({"Year": year, "Cash Flow": current_cf})
    term_val = current_cf * exit_mult
    term_pv = term_val / ((1 + discount) ** years)
    return total_npv + term_pv, pd.DataFrame(data)

# --- UI Setup ---
st.set_page_config(page_title="PRO Deep Dive Valuator", layout="wide")
st.title("🎼 PRO Statement Deep Dive & Valuation")

uploaded_file = st.file_uploader("Upload PRO CSV Statement", type=["csv"])

if uploaded_file is not None:
    raw_df = pd.read_csv(uploaded_file)
    
    st.sidebar.header("Mapping & Filters")
    date_col = st.sidebar.selectbox("Date Column", raw_df.columns)
    rev_col = st.sidebar.selectbox("Revenue Column", raw_df.columns)
    title_col = st.sidebar.selectbox("Song Title Column", raw_df.columns)

    try:
        # Convert and Clean
        raw_df[date_col] = pd.to_datetime(raw_df[date_col])
        raw_df[rev_col] = pd.to_numeric(raw_df[rev_col], errors='coerce').fillna(0)
        
        # 1. Top Songs Analysis
        st.subheader("🎵 Top Song Contribution")
        top_songs = raw_df.groupby(title_col)[rev_col].sum().sort_values(ascending=False).reset_index()
        top_songs['Contribution %'] = (top_songs[rev_col] / top_songs[rev_col].sum()) * 100
        
        col1, col2 = st.columns([1, 2])
        with col1:
            st.dataframe(top_songs.head(10).style.format({rev_col: "${:,.2f}", "Contribution %": "{:.1f}%"}))
        with col2:
            fig_pie = px.pie(top_songs.head(10), values=rev_col, names=title_col, hole=0.4,
                             title="Revenue Concentration (Top 10)")
            st.plotly_chart(fig_pie, use_container_width=True)

        # 2. Historical Aggregation
        annual_rev = raw_df.groupby(raw_df[date_col].dt.year)[rev_col].sum().reset_index()
        annual_rev.columns = ['Year', 'Revenue']
        ltm_rev = annual_rev['Revenue'].iloc[-1]
        
        # 3. Valuation Section
        st.divider()
        st.subheader("💰 Valuation Projection")
        
        v1, v2, v3 = st.columns(3)
        with v1:
            decay = st.slider("Annual Decay (%)", 0, 40, 6) / 100
        with v2:
            discount = st.slider("Discount Rate (%)", 5, 25, 12) / 100
        with v3:
            exit_mult = st.number_input("Exit Multiple", value=12.0)

        total_val, _ = calculate_valuation(ltm_rev, decay, discount, 10, exit_mult)
        
        st.metric("Total Catalog Valuation", f"${total_val:,.2f}", 
                  delta=f"Implied Multiple: {total_val/ltm_rev:.1f}x")

    except Exception as e:
        st.error(f"Error: {e}. Check if your CSV column names match your selections.")

else:
    st.info("Upload a CSV (BMI, ASCAP, etc.) to analyze song-level performance.")
